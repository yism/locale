{
  "id": "enterprise-strict",
  "version": "2026-03-v0.1",
  "priority": 100,
  "default_outcomes": {
    "network": "allow_with_warning"
  },
  "budget_overrides": {},
  "scope_overrides": [
    {
      "action_class": "read",
      "resource": "path:/etc/*",
      "outcome": "deny"
    },
    {
      "action_class": "network",
      "resource": "host:internal.*",
      "outcome": "deny"
    }
  ],
  "environment_overrides": {
    "prod": {
      "default_outcomes": {
        "write": "deny",
        "admin": "deny"
      },
      "budget_overrides": {}
    }
  }
}
